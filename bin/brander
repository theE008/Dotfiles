#!/usr/bin/env python3
import sys
import os
from PIL import Image, ImageDraw, ImageFont
from pathlib import Path

def add_watermark(image_path):
    # Setup paths
    img_path = Path(image_path)
    if not img_path.is_file():
        print(f"Error: {image_path} not found.")
        return

    # Open image
    with Image.open(img_path).convert("RGBA") as base:
        # Create a layer for the text
        txt_layer = Image.new("RGBA", base.size, (255, 255, 255, 0))
        draw = ImageDraw.Draw(txt_layer)
        
        # --- DYNAMIC CONFIGURATION ---
        text = "KAVATRON v8"
        
        # Ratios based on your 1280px wide preference:
        # font_size: 100/1280 ≈ 0.078
        # margin: 50/1280 ≈ 0.039
        font_size = int(base.width * 0.078)
        margin = int(base.width * 0.039)
        shadow_offset = max(2, int(base.width * 0.003)) 
        
        # Potential paths for Terminus on Arch
        font_paths = [
            "/usr/share/fonts/TTF/TerminessNerdFont-Bold.ttf",
            "/usr/share/fonts/terminess-nerd/TerminessNerdFont-Bold.ttf"
        ]
        
        font = None
        for p in font_paths:
            if os.path.exists(p):
                try:
                    font = ImageFont.truetype(p, font_size)
                    break
                except:
                    continue
        
        if not font:
            print("Terminus font not found, using default (it might be tiny!).")
            font = ImageFont.load_default()

        # Position calculation
        bbox = draw.textbbox((0, 0), text, font=font)
        textwidth = bbox[2] - bbox[0]
        textheight = bbox[3] - bbox[1]
        
        x = margin
        # Position at bottom-left with a proportional nudge
        y = base.height - textheight - margin - (font_size // 5)

        # Draw a subtle shadow/outline for readability
        draw.text((x + shadow_offset, y + shadow_offset), text, font=font, fill=(0, 0, 0, 150)) 
        
        # Draw the main text (Red with slight transparency)
        draw.text((x, y), text, font=font, fill=(255, 0, 0, 200))

        # Combine and save
        out = Image.alpha_composite(base, txt_layer)
        output_name = f"branded_{img_path.name}"
        
        # Final save as RGB (drops alpha for JPG compatibility)
        out.convert("RGB").save(output_name)
        print(f"Successfully branded: {output_name} (Size: {base.width}x{base.height})")

if __name__ == "__main__":
    if len(sys.argv) > 1:
        add_watermark(sys.argv[1])
    else:
        print("Usage: brand <image_path>")
