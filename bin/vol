#!/bin/sh

# If no argument is provided, just show the current volume percentage
if [ -z "$1" ]; then
    # Get volume and check for MUTED status
    RAW=$(wpctl get-volume @DEFAULT_AUDIO_SINK@)
    if echo "$RAW" | grep -q "MUTED"; then
        echo "0%"
    else
        # Extract the decimal and convert to percentage
        echo "$RAW" | awk '{printf "%d%%", $2*100}'
    fi
    exit 0
fi

# ... keep your existing VOL logic below ...
VOL=$1
if [ "$VOL" -gt 100 ]; then VOL=100; elif [ "$VOL" -lt 0 ]; then VOL=0; fi
TARGET=$(printf "%.2f" "$(echo "scale=2; $VOL / 100" | bc -l)")
wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ "$TARGET"
