#!/bin/bash

# Se não tem argumentos
if [ $# -lt 2 ]; then 

    echo ""
    echo "Uso: mk <dir> <nome>"
    echo ""

    exit 1
fi

# Variáveis
DIR="$1"
NOME="$2"
BINARIOS="$HOME/Dotfiles/bin"
BINARIO="$BINARIOS/$NOME"
EDITOR="nvim"
ARGS=0

##########################################
# Escrevendo o binário

# HEADER
echo "#!/bin/bash" > $BINARIO
echo "" >> $BINARIO

# Definindo a variável base
echo "DIR='$DIR'" >> $BINARIO
echo "EDITOR='$EDITOR'" >> $BINARIO
echo "FILE=''" >> $BINARIO

# Para descobrir quantia de argumentos
read -p "Você quer organização em subpastas? (y/N): " IN_SUBPASTAS
read -p "Deseja sempre nomear o arquivo? (y/N): " IN_CALL
if [[ "$IN_SUBPASTAS" == "y" ]]; then
    ((ARGS++))
fi
if [[ "$IN_CALL" == "y" ]]; then
    ((ARGS++))
fi

# Caso não se passe argumentos, abra o diretório
echo "if [ \$# -lt $ARGS ]; then" >> $BINARIO
echo '    cd "$DIR" && $EDITOR .' >> $BINARIO
echo '    exit 0' >> $BINARIO

# Caso passe...
echo 'else' >> $BINARIO

    # Garante que o usuário quer organização ano/mês
    read -p "Você quer organização ano/mês? (y/N): " IN_ANOMES
    if [[ "$IN_ANOMES" == "y" ]]; then 
        echo '    AM=$(date +%y-%m)' >> $BINARIO
        echo '    DIR=$DIR/$AM' >> $BINARIO
        echo '    mkdir -p "$DIR"' >> $BINARIO
    fi

    # Garante que o usuário quer organização em subpastas
    if [[ "$IN_SUBPASTAS" == "y" ]]; then 
        echo '    DIR=$DIR/$1' >> $BINARIO
        echo '    FILE=$FILE_$1' >> $BINARIO
        echo '    shift || true' >> $BINARIO
        echo '    if [ ! -d "$DIR" ]; then' >> $BINARIO
        echo '        echo "Não encontrado!"' >> $BINARIO
        echo '        read -p "Deseja Criar? (y/N): " IN_CRIAR' >> $BINARIO
        echo '        if [[ "$IN_CRIAR" == "y" ]]; then' >> $BINARIO
        echo '            mkdir -p "$DIR"' >> $BINARIO
        echo '        else' >> $BINARIO 
        echo '            echo "Diretório não encontrado!"' >> $BINARIO
        echo '            exit 1' >> $BINARIO
        echo '        fi' >> $BINARIO
        echo '    fi' >> $BINARIO
    fi

    # Garante que o usuário quer nomeclatura em datas
    read -p "Você quer nomeclatura em datas? (y/N): " IN_NOME 
    if [[ "$IN_NOME" == "y" ]]; then 
        echo '    FILE=$FILE$(date +%y-%m-%d)' >> $BINARIO
    fi

    # Garante que o usuário quer nomear o arquivo
    if [[ "$IN_CALL" == "y" ]]; then 
        echo '    FILE=$FILE_$1' >> $BINARIO
        echo '    shift || true' >> $BINARIO
    fi

    # Pega a extensão de arquivo que o usuário deseja 
    read -p "Qual extensão de arquivo? (ex: .md) " IN_EXT
    echo "    IN_EXT=$IN_EXT" >> $BINARIO
    echo '    FILE=$FILE$IN_EXT' >> $BINARIO

    # Por fim, abre a pasta e executa
    echo '  cd "$DIR" && $EDITOR "$FILE"' >>  $BINARIO

# Finaliza
echo 'fi' >> $BINARIO

# FOOTER
echo "" >> $BINARIO
echo "# Feito com MK-KT" >> $BINARIO

##########################################
# Finalizando

chmod +x "$BINARIO"
