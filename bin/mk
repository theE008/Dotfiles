#!/bin/bash

# Default flags
USE_DATE=false
USE_TYPE=false
USE_MONTH=false

# Parse flags
while getopts "dtm" opt; do
  case $opt in
    d) USE_DATE=true ;;
    t) USE_TYPE=true ;;
    m) USE_MONTH=true ;;
    *) echo "Usage: mk [-dtm] <path> <new_script_name> <ext>"; exit 1 ;;
  esac
done
shift $((OPTIND -1))

TARGET_PATH=$1
SCRIPT_NAME=$2
EXTENSION=$3
BIN_DIR="$HOME/Dotfiles/bin"
NEW_SCRIPT="$BIN_DIR/$SCRIPT_NAME"

if [ -z "$TARGET_PATH" ] || [ -z "$SCRIPT_NAME" ] || [ -z "$EXTENSION" ]; then
    echo "Usage: mk [-dtm] <path> <script_name> <extension>"
    echo "Example: mk -dm ~/Documents/Obsidian/_Daily/ mkdaily md"
    exit 1
fi

# Clean extension (remove dot if user included it)
EXTENSION="${EXTENSION#.}"

# --- Start Generating the Script ---
cat << EOF > "$NEW_SCRIPT"
#!/bin/bash
# Generated by mk

BASE_DIR="$TARGET_PATH"
EXT="$EXTENSION"
EOF

# Logic for Type (-t): Prepends a folder name from the first argument
if $USE_TYPE; then
    cat << 'EOF' >> "$NEW_SCRIPT"
if [ -z "$1" ]; then
    echo "Usage: $0 <folder_type> [filename]"
    exit 1
fi
BASE_DIR="\$BASE_DIR/\$1"
shift
EOF
fi

# Logic for Monthly (-m): Appends YYYY-MM to the path
if $USE_MONTH; then
    cat << 'EOF' >> "$NEW_SCRIPT"
BASE_DIR="\$BASE_DIR/\$(date +%Y-%m)"
EOF
fi

# File naming and execution logic
cat << EOF >> "$NEW_SCRIPT"
mkdir -p "\$BASE_DIR"

if $USE_DATE; then
    FILENAME="\$(date +%Y-%m-%d).\$EXT"
else
    if [ -z "\$1" ]; then
        # Pick existing or input new
        FILENAME=\$(find "\$BASE_DIR" -maxdepth 1 -type f -printf "%P\n" | fzf --reverse --header="Edit file (or ESC for new):")
        if [ -z "\$FILENAME" ]; then
            read -p "New filename (without ext): " NEW_NAME
            [ -z "\$NEW_NAME" ] && exit 1
            FILENAME="\$NEW_NAME.\$EXT"
        fi
    else
        FILENAME="\$1.\$EXT"
    fi
fi

TARGET="\$BASE_DIR/\$FILENAME"

# Auto-boilerplate for scripts/bins
if [[ "\$EXT" == "sh" || "\$BASE_DIR" == *"bin"* ]]; then
    if [ ! -f "\$TARGET" ]; then
        echo "#!/bin/bash" > "\$TARGET"
        chmod +x "\$TARGET"
    fi
fi

nvim "\$TARGET"
EOF

chmod +x "$NEW_SCRIPT"
echo "✅ Tool '$SCRIPT_NAME' created for .$EXTENSION files in $TARGET_PATH"
