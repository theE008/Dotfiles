#!/bin/bash
# ~/.local/bin/bt_status

# Check if the Bluetooth radio is actually powered on
if bluetoothctl show | grep -q "Powered: yes"; then
    # Check if there is any device currently in the "Connected" list
    if [[ -n $(bluetoothctl devices Connected) ]]; then
        echo "󰂱 " # Connected icon (Active)
    else
        echo "󰂯 " # On but no devices (Searching/Idle)
    fi
else
    echo "" # Bluetooth is off: stay silent
fi
