#!/bin/sh

CONFIG_PATH="$HOME/Dotfiles/config"

if [ -z "$1" ]; then
    # No argument? Let me pick from the list
    # find lists files, fzf filters them, nvim opens the winner
    FILE=$(find "$CONFIG_PATH" -type f -printf "%P\n" | fzf --height 40% --reverse --header="Edit Config:")
    [ -n "$FILE" ] && nvim "$CONFIG_PATH/$FILE"
else
    # Argument given? Open it directly
    nvim "$CONFIG_PATH/$1"
fi
