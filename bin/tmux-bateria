#!/bin/sh

# Change BAT0 to BAT1 if your laptop uses a different index
BAT="/sys/class/power_supply/BAT1"

# Check if battery exists (some laptops use different names)
if [ ! -d "$BAT" ]; then
    echo ""
    exit 0
fi

PERC=$(cat "$BAT/capacity")
STATUS=$(cat "$BAT/status")

# Set symbols based on status
if [ "$STATUS" = "Charging" ]; then
    ICON="⚡"
elif [ "$PERC" -lt 20 ]; then
    ICON="!"  # Low battery warning
else
    ICON="🔋"
fi

echo "$ICON $PERC%"
